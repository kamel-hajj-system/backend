// Prisma schema for Kamel System - User Management Module
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  Company
  ServiceCenter
  SuperAdmin
}

enum Role {
  Supervisor
  EmpRead
  EmpManage
}

model Shift_Location {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  locationAr  String?  @map("location_ar")
  // Optional circle geofence (meters) for attendance
  zoneCenterLat    Float?  @map("zone_center_lat")
  zoneCenterLng    Float?  @map("zone_center_lng")
  zoneRadiusMeters Int?    @map("zone_radius_meters")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users  User[]

  @@map("shift_locations")
}

model Shift {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  shiftAr        String?  @map("shift_ar")
  startTime      DateTime @map("start_time") @db.Time
  endTime        DateTime @map("end_time") @db.Time
  isForEmployee  Boolean  @default(true) @map("is_for_employee")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users              User[]
  attendanceRecords  AttendanceRecord[]

  @@map("shifts")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  fullName        String    @map("full_name")
  fullNameAr      String?   @map("full_name_ar")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  phone           String?
  userType        UserType  @map("user_type")
  role            Role      @default(EmpRead)
  jobTitle        String?   @map("job_title")
  shiftId         String?   @map("shift_id") @db.Uuid
  locationId      String?   @map("location_id") @db.Uuid
  supervisorId    String?   @map("supervisor_id") @db.Uuid
  serviceCenterId String?   @map("service_center_id") @db.Uuid
  isActive        Boolean   @default(true) @map("is_active")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  isSuperAdmin    Boolean   @default(false) @map("is_super_admin")
  isHr            Boolean   @default(false) @map("is_hr")
  tokenVersion    Int       @default(0) @map("token_version")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  shift           Shift?          @relation(fields: [shiftId], references: [id])
  shiftLocation   Shift_Location? @relation(fields: [locationId], references: [id])
  supervisor       User?    @relation("UserSupervisor", fields: [supervisorId], references: [id])
  subordinates     User[]   @relation("UserSupervisor")

  accessGrants     AccessGrant[]
  attendanceRecords AttendanceRecord[]
  refreshSessions  RefreshSession[]
  auditLogs        AuditLog[]
  createdNotifications Notification[] @relation("NotificationCreator")
  notificationRecipients NotificationRecipient[]
  pushSubscriptions    PushSubscription[]

  @@index([email])
  @@index([isDeleted, isActive])
  @@index([supervisorId])
  @@index([serviceCenterId])
  @@index([shiftId])
  @@index([locationId])
  @@map("users")
}

model RefreshSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @map("token_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?  @map("replaced_by_id") @db.Uuid

  user         User     @relation(fields: [userId], references: [id])
  replacedBy   RefreshSession? @relation("RefreshReplace", fields: [replacedById], references: [id])
  replaces     RefreshSession[] @relation("RefreshReplace")

  @@index([userId, expiresAt])
  @@index([tokenHash])
  @@map("refresh_sessions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  ip        String?
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AccessGrant {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  code      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, code])
  @@index([code])
  @@map("access_grants")
}

model AttendanceRecord {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  shiftId       String    @map("shift_id") @db.Uuid

  // Shift instance boundaries in Asia/Riyadh (can cross midnight)
  shiftStartAt  DateTime  @map("shift_start_at")
  shiftEndAt    DateTime  @map("shift_end_at")

  checkInAt     DateTime? @map("check_in_at")
  checkOutAt    DateTime? @map("check_out_at")

  checkInLat           Float?   @map("check_in_lat")
  checkInLng           Float?   @map("check_in_lng")
  checkInAccuracyMeters Float?  @map("check_in_accuracy_meters")
  checkInInsideZone    Boolean? @map("check_in_inside_zone")

  checkOutLat           Float?   @map("check_out_lat")
  checkOutLng           Float?   @map("check_out_lng")
  checkOutAccuracyMeters Float?  @map("check_out_accuracy_meters")
  checkOutInsideZone    Boolean? @map("check_out_inside_zone")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id])
  shift         Shift     @relation(fields: [shiftId], references: [id])

  @@unique([userId, shiftStartAt])
  @@index([userId, checkInAt, checkOutAt])
  @@index([shiftId, shiftStartAt])
  @@map("attendance_records")
}

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  title       String?
  message     String
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  createdBy   User? @relation("NotificationCreator", fields: [createdById], references: [id])
  recipients  NotificationRecipient[]

  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String   @map("notification_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  isRead         Boolean  @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@index([userId, isRead, createdAt])
  @@map("notification_recipients")
}

/// Browser Web Push subscription (one row per device / endpoint).
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String   @map("p256dh")
  auth      String
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}
