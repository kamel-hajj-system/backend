{
  "name": "kamel-system-backend",
  "version": "1.0.0",
  "description": "Backend for Kamel System - Express + PostgreSQL API server",
  "main": "src/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "prestart": "prisma generate",
    "predev": "prisma generate",
    "start": "node src/index.js",
    "start:with-db": "prisma generate && prisma db push && node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:local": "PORT=5001 nodemon src/index.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "prisma generate && prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:baseline-resolve": "prisma migrate resolve --applied 20250331120000_baseline",
    "db:ensure": "node scripts/ensure-migrations.js",
    "db:guard-schema": "node scripts/check-schema-sync.js",
    "db:setup": "node scripts/seed-superadmin.js",
    "db:seed": "node scripts/seed-superadmin.js",
    "vapid:keys": "npx web-push generate-vapid-keys",
    "test": "node --test modules/users/tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "prisma": "^5.22.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  }
}
