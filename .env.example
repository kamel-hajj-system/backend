# Server
PORT=5001

# Behind Dokploy / Nginx / Traefik: trust proxy is ON by default in production (see src/index.js).
# Set TRUST_PROXY=0 only if the app is exposed directly with no reverse proxy.
# For two hops (e.g. outer LB + inner proxy), set TRUST_PROXY=2.
# TRUST_PROXY=1

# Dokploy / first deploy after schema changes: apply DB schema before start, e.g.
#   npm run start:with-db
# or run once: npx prisma db push && npx prisma generate

# Database (use DATABASE_URL or PG* vars)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=postgres
DB_SSL=false

# JWT (required in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Super Admin (required in production; set in Dokploy → Environment)
# In development, if unset, defaults to superadmin/superadmin for convenience.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Web Push (optional — generate with: npx web-push generate-vapid-keys)
# VAPID_SUBJECT must be a mailto: or https: URL (e.g. mailto:admin@yourdomain.com)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@kamel-system.com
